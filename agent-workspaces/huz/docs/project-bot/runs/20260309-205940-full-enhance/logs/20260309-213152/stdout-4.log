diff --git a/huz/settings_test.py b/huz/settings_test.py
new file mode 100644
index 0000000000000000000000000000000000000000..99009f0b28bcff7df3c69feb86387c6e613b38ff
--- /dev/null
+++ b/huz/settings_test.py
@@ -0,0 +1,23 @@
+from .settings import *  # noqa: F401,F403
+
+
+# Force a local DB for non-interactive test runs so verification does not
+# depend on the remote MySQL instance declared in `.env`.
+DATABASES = {
+    "default": {
+        "ENGINE": "django.db.backends.sqlite3",
+        "NAME": BASE_DIR / "test.sqlite3",
+    }
+}
+
+PASSWORD_HASHERS = [
+    "django.contrib.auth.hashers.MD5PasswordHasher",
+]
+
+EMAIL_BACKEND = "django.core.mail.backends.locmem.EmailBackend"
+
+CHANNEL_LAYERS = {
+    "default": {
+        "BACKEND": "channels.layers.InMemoryChannelLayer",
+    }
+}

