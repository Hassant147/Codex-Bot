+        };
+
+        setSupportSuccessMessage(
+          successMessageByAction[activeSupportAction] ||
+            "Support action submitted successfully."
+        );
+        resetSupportModal();
+      });
+    } catch (error) {
+      setSupportErrorMessage(
+        error?.message || "Failed to submit the selected support action."
+      );
+    } finally {
+      setIsSubmittingSupport(false);
+    }
+  };
