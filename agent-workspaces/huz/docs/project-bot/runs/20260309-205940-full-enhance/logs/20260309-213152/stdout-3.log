+
+          response = await updateObjectionResponse(
+            "",
+            bookingNumber,
+            supportFormState.objectionDocument,
+            supportFormState.objectionRemarks.trim(),
+            objectionId
+          );
+        }
+
+        if (response?.success === false) {
+          throw new Error(response.error || "Failed to submit support action.");
+        }
+
+        await refreshBookingDetail();
+
+        const successMessageByAction = {
+          complaint:
+            "Complaint submitted. Track future updates from Help & Complaints.",
+          request:
