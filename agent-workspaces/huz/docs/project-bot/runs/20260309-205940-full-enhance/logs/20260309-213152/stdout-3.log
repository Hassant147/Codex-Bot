+++ b/src/pages/UserSetting/Support/supportUtils.js
@@ -0,0 +1,126 @@
+import { normalizeBookingFlowStatus } from "../../../features/booking/utils/bookingFlowUtils";
+
+const REVIEW_ELIGIBLE_STATUSES = new Set(["completed", "closed", "close"]);
+const REQUEST_ELIGIBLE_STATUSES = new Set(["completed", "active", "closed"]);
+const COMPLAINT_ELIGIBLE_STATUSES = new Set([
+  "pending",
+  "completed",
+  "active",
+  "closed",
+  "close",
+]);
+const OBJECTION_ELIGIBLE_STATUSES = new Set(["objection"]);
+
+const SUPPORT_STATUS_CLASS_MAP = {
+  open: "border-[#d5e8de] bg-[#f0faf6] text-[#067a5d]",
+  inprogress: "border-[#eadfbe] bg-[#fff9ef] text-[#9a6d17]",
+  pending: "border-[#eadfbe] bg-[#fff9ef] text-[#9a6d17]",
+  resolved: "border-[#d5e8de] bg-[#f0faf6] text-[#067a5d]",
+  closed: "border-[#d5e8de] bg-[#f0faf6] text-[#067a5d]",
+  approved: "border-[#d5e8de] bg-[#f0faf6] text-[#067a5d]",
+  rejected: "border-[#f2d7d7] bg-[#fff7f7] text-[#b54747]",
+};
+
+const SUPPORT_DATE_FORMATTER = new Intl.DateTimeFormat("en-US", {
+  month: "short",
+  day: "numeric",
+  year: "numeric",
+});
+
+const toStatusLabel = (value = "") =>
+  String(value || "")
+    .trim()
+    .replace(/[_-]+/g, " ")
+    .replace(/\s+/g, " ")
+    .toLowerCase()
+    .replace(/\b\w/g, (character) => character.toUpperCase());
+
+export const COMPLAINT_ATTACHMENT_ACCEPT = ".png,.jpg,.jpeg,.pdf,.doc,.docx";
+export const REQUEST_ATTACHMENT_ACCEPT = ".png,.jpg,.jpeg,.gif,.pdf";
+export const COMPLAINT_AUDIO_ACCEPT = ".aac,.mp3,.wav,.m4a,audio/*";
+export const OBJECTION_DOCUMENT_ACCEPT = ".png,.jpg,.jpeg,.pdf,.doc,.docx";
+
+export const formatSupportDate = (value) => {
+  if (!value) {
+    return "Recent";
+  }
+
+  const parsed = new Date(value);
+  if (Number.isNaN(parsed.getTime())) {
+    return "Recent";
+  }
+
+  return SUPPORT_DATE_FORMATTER.format(parsed);
+};
+
+export const getSupportStatusLabel = (value, fallback = "Open") => {
+  const normalized = String(value || "").trim();
+  if (!normalized) {
+    return fallback;
+  }
+
+  return toStatusLabel(normalized);
+};
+
+export const getSupportStatusClasses = (value) =>
+  SUPPORT_STATUS_CLASS_MAP[String(value || "").trim().toLowerCase()] ||
+  "border-[#dbe5e1] bg-[#f8fcfa] text-[#4b5769]";
+
+export const resolveSupportFileHref = (value) => {
+  const normalized = String(value || "").trim();
+  if (!normalized) {
+    return "";
+  }
+
+  if (/^https?:\/\//i.test(normalized)) {
+    return normalized;
+  }
+
+  return normalized.startsWith("/") ? normalized : `/${normalized}`;
+};
+
+export const hasSubmittedReview = (bookingDetail = {}) =>
+  Array.isArray(bookingDetail?.booking_rating) && bookingDetail.booking_rating.length > 0;
+
+export const getSupportActionAvailability = (bookingDetail = {}) => {
+  const bookingStatus = normalizeBookingFlowStatus(bookingDetail?.booking_status);
+  const reviewAlreadySubmitted = hasSubmittedReview(bookingDetail);
+
+  return {
+    complaint: COMPLAINT_ELIGIBLE_STATUSES.has(bookingStatus)
+      ? { enabled: true, reason: "Raise a booking complaint with the latest operator context attached." }
+      : {
+          enabled: false,
+          reason: "Complaints open once the booking is pending, active, completed, or closed.",
+        },
+    request: REQUEST_ELIGIBLE_STATUSES.has(bookingStatus)
+      ? { enabled: true, reason: "Send an operational request tied to this booking number." }
+      : {
+          enabled: false,
+          reason: "Requests open once the booking becomes active, completed, or closed.",
+        },
+    review: reviewAlreadySubmitted
+      ? {
+          enabled: false,
+          reason: "A review is already attached to this booking.",
+        }
+      : REVIEW_ELIGIBLE_STATUSES.has(bookingStatus)
+      ? {
+          enabled: true,
+          reason: "Review the operator once the booking is completed or closed.",
+        }
+      : {
+          enabled: false,
+          reason: "Reviews only unlock after the booking is completed or closed.",
+        },
+    objection: OBJECTION_ELIGIBLE_STATUSES.has(bookingStatus)
+      ? {
+          enabled: true,
+          reason: "Upload the requested document and reply to the operator objection.",
+        }
+      : {
+          enabled: false,
+          reason: "Objection responses are only available when the booking status is Objection.",
+        },
+  };
+};
