+                      onClick={() =>
+                        onValueChange({
+                          target: {
+                            name: "reviewStars",
+                            value: String(star),
+                          },
+                        })
+                      }
+                      className={`rounded-full border px-4 py-2 text-sm font-bold transition ${
+                        formState.reviewStars === star
+                          ? "border-[#d5b571] bg-[#fff9ef] text-[#9a6d17]"
+                          : "border-[#dceae3] bg-white text-[#4b5769]"
+                      }`}
+                    >
+                      {star} star{star === 1 ? "" : "s"}
+                    </button>
+                  ))}
+                </div>
+              </div>
+
+              <label className="block space-y-2">
+                <span className="text-sm font-semibold text-[#1a2734]">Review note</span>
+                <textarea
+                  className={TEXTAREA_CLASSNAME}
+                  name="reviewComment"
+                  value={formState.reviewComment}
+                  onChange={onValueChange}
+                  placeholder="Share the operator experience from this booking."
+                />
+              </label>
+            </>
+          ) : null}
+
+          {actionType === "objection" ? (
+            <>
+              <label className="block space-y-2">
+                <span className="text-sm font-semibold text-[#1a2734]">Your remarks</span>
+                <textarea
+                  className={TEXTAREA_CLASSNAME}
+                  name="objectionRemarks"
+                  value={formState.objectionRemarks}
+                  onChange={onValueChange}
+                  placeholder="Explain the clarification or document you are submitting."
+                  required
+                />
+              </label>
+
+              <label className="block space-y-2">
+                <span className="text-sm font-semibold text-[#1a2734]">Required document</span>
+                <input
+                  className={FILE_INPUT_CLASSNAME}
+                  type="file"
+                  accept={OBJECTION_DOCUMENT_ACCEPT}
+                  onChange={(event) =>
+                    onFileChange("objectionDocument", event.target.files?.[0] || null)
+                  }
+                  required
+                />
+                <p className="text-xs text-[#7a8796]">
+                  {formatFileName(formState.objectionDocument)}
+                </p>
+              </label>
+            </>
+          ) : null}
+
+          <div className="flex flex-wrap justify-end gap-3 border-t border-[#edf2ef] pt-4">
+            <Button type="button" variant="secondary" onClick={onClose} disabled={isSubmitting}>
+              Cancel
+            </Button>
+            <Button type="submit" variant="gold" disabled={isSubmitting}>
+              {isSubmitting ? "Submitting..." : modalMeta.submitLabel}
+            </Button>
+          </div>
+        </form>
+      </div>
+    </div>
+  );
+};
