+          className={`inline-flex h-11 w-11 items-center justify-center rounded-2xl ring-1 ${toneClassName}`}
+        >
+          <Icon className="h-5 w-5" />
+        </span>
+      </div>
+    </Card>
+  );
+};
+
+const SupportHistoryCard = ({ item, kind, navigate }) => {
+  const attachmentHref = resolveSupportFileHref(
+    kind === "complaint" ? item.complaint_attachment : item.request_attachment
+  );
+  const audioHref =
+    kind === "complaint" ? resolveSupportFileHref(item.audio_message) : "";
+  const partnerName =
+    item?.partner_contact_detail?.company_name ||
+    item?.partner_contact_detail?.company_of_partner?.company_name ||
+    "Assigned operator";
+  const responseMessage =
+    kind === "complaint"
+      ? item.response_message
+      : item.final_response_message || item.inProgress_message;
+
+  return (
+    <Card className="p-5 sm:p-6">
+      <div className="flex flex-wrap items-start justify-between gap-3">
+        <div className="space-y-2">
+          <div className="flex flex-wrap items-center gap-2">
+            <span
+              className={`inline-flex rounded-full border px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] ${getSupportStatusClasses(
+                kind === "complaint" ? item.complaint_status : item.request_status
+              )}`}
+            >
+              {getSupportStatusLabel(
+                kind === "complaint" ? item.complaint_status : item.request_status
+              )}
+            </span>
+            <span className="text-xs font-semibold uppercase tracking-[0.12em] text-[#7a8796]">
+              {kind === "complaint" ? "Complaint" : "Request"}
+            </span>
+          </div>
+
+          <div>
+            <h3 className="text-lg font-black tracking-tight text-[#1a2734]">
+              {kind === "complaint" ? item.complaint_title : item.request_title}
