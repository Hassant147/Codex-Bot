+      ...currentState,
+      [field]: file || null,
+    }));
+  };
+
+  const handleSupportSubmit = async (event) => {
+    event.preventDefault();
+
+    if (!bookingNumber || !activeSupportAction) {
+      return;
+    }
+
+    if (
+      activeSupportAction === "complaint" &&
+      (!supportFormState.complaintTitle.trim() ||
+        !supportFormState.complaintMessage.trim())
+    ) {
+      setSupportErrorMessage("Complaint title and details are required.");
+      return;
+    }
+
+    if (
+      activeSupportAction === "request" &&
+      (!supportFormState.requestTitle.trim() || !supportFormState.requestMessage.trim())
+    ) {
+      setSupportErrorMessage("Request title and details are required.");
+      return;
+    }
+
+    if (activeSupportAction === "review" && supportFormState.reviewStars < 1) {
+      setSupportErrorMessage("Select an operator rating before submitting the review.");
