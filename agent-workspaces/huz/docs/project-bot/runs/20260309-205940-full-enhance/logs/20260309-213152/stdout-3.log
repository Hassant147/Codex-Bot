@@ -0,0 +1,450 @@
+import React, { useEffect, useState } from "react";
+import {
+  ArrowRight,
+  Clock3,
+  FileText,
+  HelpCircle,
+  MessageCircle,
+} from "lucide-react";
+import { useNavigate } from "react-router-dom";
+import Button from "../../../components/ui/Button";
+import Card from "../../../components/ui/Card";
+import EmptyState from "../../../components/ui/EmptyState";
+import InlineError from "../../../components/ui/InlineError";
+import LoadingState from "../../../components/ui/LoadingState";
+import {
+  getAllComplaintsByUser,
+  getAllRequestsByUser,
+} from "../../../api/supportApi";
+import { buildBookingFlowPath } from "../../../features/booking/utils/bookingFlowUtils";
+import BrandPageShell from "../../../shared/layout/BrandPageShell";
+import AppPromoSection from "../../../shared/sections/AppPromoSection";
+import {
+  HOMEPAGE_MAIN_SECTION_PADDING,
+  HOMEPAGE_SECTION_STACK,
+} from "../../HomePage/homepageLayout";
+import SidebarMenu from "../sidebar";
+import {
+  formatSupportDate,
+  getSupportStatusClasses,
+  getSupportStatusLabel,
+  resolveSupportFileHref,
+} from "./supportUtils";
+
+const extractList = (payload) => {
+  if (Array.isArray(payload)) {
+    return payload;
+  }
+
+  if (Array.isArray(payload?.results)) {
+    return payload.results;
+  }
+
+  if (Array.isArray(payload?.data)) {
+    return payload.data;
+  }
+
+  return [];
+};
+
+const SummaryCard = ({ icon: Icon, label, value, tone = "brand" }) => {
+  const toneClassName =
+    tone === "gold"
+      ? "bg-[#fff9ef] text-[#9a6d17] ring-[#eadfbe]"
+      : "bg-[#f0faf6] text-[#067a5d] ring-[#d5e8de]";
+
+  return (
+    <Card className="p-4 sm:p-5">
+      <div className="flex items-start justify-between gap-3">
+        <div>
+          <p className="text-[11px] font-black uppercase tracking-[0.16em] text-[#7a8796]">
+            {label}
+          </p>
+          <p className="mt-3 text-3xl font-black tracking-tight text-[#1a2734]">
+            {value}
+          </p>
+        </div>
+
+        <span
+          className={`inline-flex h-11 w-11 items-center justify-center rounded-2xl ring-1 ${toneClassName}`}
+        >
+          <Icon className="h-5 w-5" />
+        </span>
+      </div>
+    </Card>
+  );
+};
+
+const SupportHistoryCard = ({ item, kind, navigate }) => {
+  const attachmentHref = resolveSupportFileHref(
+    kind === "complaint" ? item.complaint_attachment : item.request_attachment
+  );
+  const audioHref =
+    kind === "complaint" ? resolveSupportFileHref(item.audio_message) : "";
+  const partnerName =
+    item?.partner_contact_detail?.company_name ||
+    item?.partner_contact_detail?.company_of_partner?.company_name ||
+    "Assigned operator";
+  const responseMessage =
+    kind === "complaint"
+      ? item.response_message
+      : item.final_response_message || item.inProgress_message;
+
+  return (
+    <Card className="p-5 sm:p-6">
+      <div className="flex flex-wrap items-start justify-between gap-3">
+        <div className="space-y-2">
+          <div className="flex flex-wrap items-center gap-2">
+            <span
+              className={`inline-flex rounded-full border px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] ${getSupportStatusClasses(
+                kind === "complaint" ? item.complaint_status : item.request_status
+              )}`}
+            >
+              {getSupportStatusLabel(
+                kind === "complaint" ? item.complaint_status : item.request_status
+              )}
+            </span>
+            <span className="text-xs font-semibold uppercase tracking-[0.12em] text-[#7a8796]">
+              {kind === "complaint" ? "Complaint" : "Request"}
+            </span>
+          </div>
+
+          <div>
+            <h3 className="text-lg font-black tracking-tight text-[#1a2734]">
+              {kind === "complaint" ? item.complaint_title : item.request_title}
+            </h3>
+            <p className="mt-2 text-sm leading-relaxed text-[#4b5769]">
+              {kind === "complaint" ? item.complaint_message : item.request_message}
+            </p>
+          </div>
+        </div>
+
+        <div className="rounded-2xl border border-[#e5eeea] bg-[#f8fcfa] px-4 py-3 text-sm text-[#4b5769]">
+          <p className="font-semibold text-[#1a2734]">
+            {kind === "complaint" ? item.complaint_ticket : item.request_ticket}
+          </p>
+          <p className="mt-1 text-xs">
+            Updated{" "}
+            {formatSupportDate(
+              kind === "complaint" ? item.complaint_time : item.updated_at || item.created_at
+            )}
+          </p>
+        </div>
+      </div>
+
+      <div className="mt-4 grid gap-3 text-sm text-[#4b5769] sm:grid-cols-2 xl:grid-cols-4">
+        <div className="rounded-2xl border border-[#edf2ef] bg-white px-4 py-3">
+          <p className="text-[10px] font-black uppercase tracking-[0.14em] text-[#7a8796]">
+            Booking ref
+          </p>
+          <p className="mt-2 font-semibold text-[#1a2734]">{item.booking_number || "-"}</p>
+        </div>
+        <div className="rounded-2xl border border-[#edf2ef] bg-white px-4 py-3">
+          <p className="text-[10px] font-black uppercase tracking-[0.14em] text-[#7a8796]">
+            Package
+          </p>
+          <p className="mt-2 font-semibold text-[#1a2734]">{item.package_name || "-"}</p>
+        </div>
+        <div className="rounded-2xl border border-[#edf2ef] bg-white px-4 py-3">
+          <p className="text-[10px] font-black uppercase tracking-[0.14em] text-[#7a8796]">
+            Operator
+          </p>
+          <p className="mt-2 font-semibold text-[#1a2734]">{partnerName}</p>
+        </div>
+        <div className="rounded-2xl border border-[#edf2ef] bg-white px-4 py-3">
+          <p className="text-[10px] font-black uppercase tracking-[0.14em] text-[#7a8796]">
+            Logged
+          </p>
+          <p className="mt-2 font-semibold text-[#1a2734]">
+            {formatSupportDate(
+              kind === "complaint" ? item.complaint_time : item.created_at
+            )}
+          </p>
+        </div>
+      </div>
+
+      {responseMessage ? (
+        <div className="mt-4 rounded-2xl border border-[#d5e8de] bg-[#f0faf6] p-4">
+          <p className="text-[10px] font-black uppercase tracking-[0.14em] text-[#067a5d]">
+            Latest operator note
+          </p>
+          <p className="mt-2 text-sm leading-relaxed text-[#145847]">{responseMessage}</p>
+        </div>
+      ) : null}
+
+      <div className="mt-4 flex flex-wrap gap-3">
+        <Button
+          variant="secondary"
+          onClick={() =>
+            navigate(buildBookingFlowPath("/operator-response", item.booking_number))
+          }
+        >
+          Open related booking
+          <ArrowRight className="h-4 w-4" />
+        </Button>
+
+        {attachmentHref ? (
+          <Button
+            as="a"
+            href={attachmentHref}
+            target="_blank"
+            rel="noreferrer"
+            variant="secondary"
+          >
+            View attachment
+          </Button>
+        ) : null}
+
+        {audioHref ? (
+          <Button
+            as="a"
+            href={audioHref}
+            target="_blank"
+            rel="noreferrer"
+            variant="secondary"
+          >
+            Open audio note
+          </Button>
+        ) : null}
+      </div>
+    </Card>
+  );
+};
+
+const HelpPage = () => {
+  const navigate = useNavigate();
+  const [activeTab, setActiveTab] = useState("complaints");
+  const [complaints, setComplaints] = useState([]);
+  const [requests, setRequests] = useState([]);
+  const [errorMessage, setErrorMessage] = useState("");
+  const [isLoading, setIsLoading] = useState(true);
+
+  const loadSupportHistory = async () => {
+    setIsLoading(true);
+    setErrorMessage("");
+
+    try {
+      const [complaintsResponse, requestsResponse] = await Promise.all([
+        getAllComplaintsByUser(),
+        getAllRequestsByUser(),
+      ]);
+
+      const nextErrors = [];
+
+      if (complaintsResponse?.success) {
+        setComplaints(extractList(complaintsResponse.data));
+      } else {
+        setComplaints([]);
+        nextErrors.push(complaintsResponse?.error || "Failed to load complaints.");
+      }
+
+      if (requestsResponse?.success) {
+        setRequests(extractList(requestsResponse.data));
+      } else {
+        setRequests([]);
+        nextErrors.push(requestsResponse?.error || "Failed to load requests.");
+      }
+
+      setErrorMessage(nextErrors.join(" "));
+    } catch (error) {
+      setComplaints([]);
+      setRequests([]);
+      setErrorMessage(error?.message || "Failed to load support history.");
+    } finally {
+      setIsLoading(false);
+    }
+  };
+
+  useEffect(() => {
+    loadSupportHistory();
+  }, []);
+
+  const activeItems = activeTab === "complaints" ? complaints : requests;
+  const openCases = [...complaints, ...requests].filter((item) => {
+    const status = String(
+      item?.complaint_status || item?.request_status || ""
+    ).trim().toLowerCase();
+
+    return status && !["closed", "resolved", "approved"].includes(status);
+  }).length;
+
+  return (
+    <BrandPageShell
+      mainClassName={HOMEPAGE_MAIN_SECTION_PADDING}
+      shellClassName={HOMEPAGE_SECTION_STACK}
+      preFooter={<AppPromoSection />}
+      withAmbient
+    >
+      <section className="homepage-section-surface overflow-hidden p-4 sm:p-6 md:p-8 xl:p-10">
+        <div className="grid gap-5 xl:grid-cols-[280px_minmax(0,1fr)] xl:items-start">
+          <div className="xl:sticky xl:top-24">
+            <SidebarMenu />
+          </div>
+
+          <div className="space-y-5">
+            <Card className="overflow-hidden border-[#d5e8de] bg-[linear-gradient(135deg,rgba(255,255,255,0.98),rgba(240,250,246,0.92))] p-5 sm:p-7">
+              <div className="flex flex-wrap items-start justify-between gap-4">
+                <div className="max-w-3xl space-y-3">
+                  <span className="inline-flex rounded-full border border-[#d5e8de] bg-white px-3 py-1 text-[11px] font-black uppercase tracking-[0.16em] text-[#067a5d]">
+                    Help & Complaints
+                  </span>
+                  <div className="space-y-2">
+                    <h1 className="text-3xl font-black tracking-tight text-[#1a2734] sm:text-4xl">
+                      Track support history without losing booking context
+                    </h1>
+                    <p className="max-w-2xl text-sm leading-relaxed text-[#4b5769] sm:text-[15px]">
+                      Review complaint and request activity tied to your Huz bookings.
+                      New complaints, requests, reviews, and objection responses now start
+                      from each booking&apos;s operator response page.
+                    </p>
+                  </div>
+                </div>
+
+                <Button
+                  variant="gold"
+                  className="w-full sm:w-auto"
+                  onClick={() => navigate("/booking-status")}
+                >
+                  Open bookings
+                  <ArrowRight className="h-4 w-4" />
+                </Button>
+              </div>
+
+              <div className="mt-5 grid gap-3 md:grid-cols-3">
+                <SummaryCard
+                  icon={MessageCircle}
+                  label="Complaints"
+                  value={complaints.length}
+                />
+                <SummaryCard
+                  icon={FileText}
+                  label="Requests"
+                  value={requests.length}
+                />
+                <SummaryCard
+                  icon={Clock3}
+                  label="Open cases"
+                  value={openCases}
+                  tone="gold"
+                />
+              </div>
+            </Card>
+
+            {errorMessage ? (
+              <InlineError message={errorMessage} onRetry={loadSupportHistory} />
+            ) : null}
+
+            <Card className="p-5 sm:p-6">
+              <div className="flex flex-wrap items-start justify-between gap-4">
+                <div className="space-y-2">
+                  <div className="flex items-center gap-2 text-[#067a5d]">
+                    <HelpCircle className="h-4 w-4" />
+                    <span className="text-[11px] font-black uppercase tracking-[0.16em]">
+                      Support routing
+                    </span>
+                  </div>
+                  <h2 className="text-xl font-black tracking-tight text-[#1a2734]">
+                    Reviews now live inside the booking flow
+                  </h2>
+                  <p className="max-w-3xl text-sm leading-relaxed text-[#4b5769]">
+                    There is no separate reviews page anymore. When a booking reaches a
+                    completed or closed state, open that booking&apos;s operator response
+                    page to submit the review directly against the correct booking number.
+                  </p>
+                </div>
+
+                <Button
+                  variant="secondary"
+                  className="w-full sm:w-auto"
+                  onClick={() => navigate("/booking-status")}
+                >
+                  Go to booking flow
+                </Button>
+              </div>
+            </Card>
+
+            <Card className="p-5 sm:p-6">
+              <div className="flex flex-wrap items-center justify-between gap-3">
+                <div>
+                  <p className="text-[11px] font-black uppercase tracking-[0.16em] text-[#7a8796]">
+                    History
+                  </p>
+                  <h2 className="mt-2 text-2xl font-black tracking-tight text-[#1a2734]">
+                    Current support cases
+                  </h2>
+                </div>
+
+                <div className="inline-flex rounded-full border border-[#dceae3] bg-[#f8fcfa] p-1">
+                  <button
+                    type="button"
+                    onClick={() => setActiveTab("complaints")}
+                    className={`rounded-full px-4 py-2 text-sm font-bold transition-colors ${
+                      activeTab === "complaints"
+                        ? "bg-white text-[#067a5d] shadow-[0_10px_24px_rgba(0,92,67,0.08)]"
+                        : "text-[#667085]"
+                    }`}
+                  >
+                    Complaints
+                  </button>
+                  <button
+                    type="button"
+                    onClick={() => setActiveTab("requests")}
+                    className={`rounded-full px-4 py-2 text-sm font-bold transition-colors ${
+                      activeTab === "requests"
+                        ? "bg-white text-[#067a5d] shadow-[0_10px_24px_rgba(0,92,67,0.08)]"
+                        : "text-[#667085]"
+                    }`}
+                  >
+                    Requests
+                  </button>
+                </div>
+              </div>
+
+              <div className="mt-5">
+                {isLoading ? (
+                  <LoadingState
+                    label="Loading your support history..."
+                    className="min-h-[260px]"
+                  />
+                ) : activeItems.length ? (
+                  <div className="space-y-4">
+                    {activeItems.map((item) => (
+                      <SupportHistoryCard
+                        key={
+                          activeTab === "complaints"
+                            ? item.complaint_id || item.complaint_ticket
+                            : item.request_id || item.request_ticket
+                        }
+                        item={item}
+                        kind={activeTab === "complaints" ? "complaint" : "request"}
+                        navigate={navigate}
+                      />
+                    ))}
+                  </div>
+                ) : (
+                  <EmptyState
+                    title={
+                      activeTab === "complaints"
+                        ? "No complaints submitted yet"
