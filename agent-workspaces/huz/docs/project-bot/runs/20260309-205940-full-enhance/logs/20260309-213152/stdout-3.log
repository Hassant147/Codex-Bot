+    try {
+      await runWithSupportLock(async () => {
+        let response = null;
+
+        if (activeSupportAction === "complaint") {
+          response = await submitBookingComplaint({
+            booking_number: bookingNumber,
+            complaint_title: supportFormState.complaintTitle.trim(),
+            complaint_message: supportFormState.complaintMessage.trim(),
+            complaint_attachment: supportFormState.complaintAttachment,
+            audio_message: supportFormState.complaintAudio,
+          });
+        }
+
+        if (activeSupportAction === "request") {
+          response = await submitBookingRequest({
+            booking_number: bookingNumber,
+            request_title: supportFormState.requestTitle.trim(),
+            request_message: supportFormState.requestMessage.trim(),
+            request_attachment: supportFormState.requestAttachment,
+          });
+        }
+
+        if (activeSupportAction === "review") {
+          response = await submitRatingAndReview({
+            booking_number: bookingNumber,
+            partner_total_stars: supportFormState.reviewStars,
+            partner_comment: supportFormState.reviewComment.trim(),
+          });
+        }
+
+        if (activeSupportAction === "objection") {
+          const objectionId = bookingDetail?.booking_objections?.[0]?.objection_id;
+          if (!objectionId) {
+            throw new Error("No objection record was found for this booking.");
+          }
+
+          response = await updateObjectionResponse(
+            "",
+            bookingNumber,
+            supportFormState.objectionDocument,
+            supportFormState.objectionRemarks.trim(),
+            objectionId
+          );
+        }
+
+        if (response?.success === false) {
+          throw new Error(response.error || "Failed to submit support action.");
+        }
+
+        await refreshBookingDetail();
+
+        const successMessageByAction = {
+          complaint:
+            "Complaint submitted. Track future updates from Help & Complaints.",
+          request:
+            "Request submitted. Track future updates from Help & Complaints.",
+          review: "Review submitted for this booking.",
+          objection:
+            "Objection response submitted. The booking status has been refreshed.",
+        };
+
+        setSupportSuccessMessage(
+          successMessageByAction[activeSupportAction] ||
+            "Support action submitted successfully."
+        );
+        resetSupportModal();
+      });
+    } catch (error) {
+      setSupportErrorMessage(
+        error?.message || "Failed to submit the selected support action."
+      );
+    } finally {
+      setIsSubmittingSupport(false);
+    }
+  };
+
   const stateLabel =
     loadState === BOOKING_DETAIL_LOAD_STATE.ready
