+                  <div className="space-y-2">
+                    <h1 className="text-3xl font-black tracking-tight text-[#1a2734] sm:text-4xl">
+                      Track support history without losing booking context
+                    </h1>
+                    <p className="max-w-2xl text-sm leading-relaxed text-[#4b5769] sm:text-[15px]">
+                      Review complaint and request activity tied to your Huz bookings.
+                      New complaints, requests, reviews, and objection responses now start
+                      from each booking&apos;s operator response page.
+                    </p>
+                  </div>
+                </div>
+
+                <Button
+                  variant="gold"
+                  className="w-full sm:w-auto"
+                  onClick={() => navigate("/booking-status")}
+                >
+                  Open bookings
+                  <ArrowRight className="h-4 w-4" />
+                </Button>
+              </div>
+
+              <div className="mt-5 grid gap-3 md:grid-cols-3">
+                <SummaryCard
+                  icon={MessageCircle}
+                  label="Complaints"
+                  value={complaints.length}
+                />
+                <SummaryCard
+                  icon={FileText}
+                  label="Requests"
+                  value={requests.length}
+                />
+                <SummaryCard
+                  icon={Clock3}
+                  label="Open cases"
+                  value={openCases}
+                  tone="gold"
+                />
+              </div>
+            </Card>
+
+            {errorMessage ? (
+              <InlineError message={errorMessage} onRetry={loadSupportHistory} />
+            ) : null}
+
+            <Card className="p-5 sm:p-6">
+              <div className="flex flex-wrap items-start justify-between gap-4">
+                <div className="space-y-2">
+                  <div className="flex items-center gap-2 text-[#067a5d]">
+                    <HelpCircle className="h-4 w-4" />
+                    <span className="text-[11px] font-black uppercase tracking-[0.16em]">
+                      Support routing
+                    </span>
+                  </div>
+                  <h2 className="text-xl font-black tracking-tight text-[#1a2734]">
+                    Reviews now live inside the booking flow
+                  </h2>
+                  <p className="max-w-3xl text-sm leading-relaxed text-[#4b5769]">
+                    There is no separate reviews page anymore. When a booking reaches a
+                    completed or closed state, open that booking&apos;s operator response
+                    page to submit the review directly against the correct booking number.
+                  </p>
+                </div>
+
+                <Button
+                  variant="secondary"
+                  className="w-full sm:w-auto"
+                  onClick={() => navigate("/booking-status")}
+                >
+                  Go to booking flow
+                </Button>
+              </div>
+            </Card>
+
+            <Card className="p-5 sm:p-6">
+              <div className="flex flex-wrap items-center justify-between gap-3">
+                <div>
+                  <p className="text-[11px] font-black uppercase tracking-[0.16em] text-[#7a8796]">
+                    History
+                  </p>
+                  <h2 className="mt-2 text-2xl font-black tracking-tight text-[#1a2734]">
+                    Current support cases
+                  </h2>
+                </div>
+
+                <div className="inline-flex rounded-full border border-[#dceae3] bg-[#f8fcfa] p-1">
+                  <button
+                    type="button"
+                    onClick={() => setActiveTab("complaints")}
+                    className={`rounded-full px-4 py-2 text-sm font-bold transition-colors ${
+                      activeTab === "complaints"
+                        ? "bg-white text-[#067a5d] shadow-[0_10px_24px_rgba(0,92,67,0.08)]"
+                        : "text-[#667085]"
