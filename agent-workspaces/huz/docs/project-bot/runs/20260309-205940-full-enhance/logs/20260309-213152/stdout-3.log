+      );
+      return;
+    }
+
+    setSupportErrorMessage("");
+    setSupportSuccessMessage("");
+    setIsSubmittingSupport(true);
+
+    try {
+      await runWithSupportLock(async () => {
+        let response = null;
+
+        if (activeSupportAction === "complaint") {
+          response = await submitBookingComplaint({
+            booking_number: bookingNumber,
+            complaint_title: supportFormState.complaintTitle.trim(),
+            complaint_message: supportFormState.complaintMessage.trim(),
+            complaint_attachment: supportFormState.complaintAttachment,
