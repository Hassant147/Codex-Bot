  } else {
    backendMap.get(ep).sources.add(item.source);
  }
}

const backendEndpoints = Array.from(backendMap.values()).map((x) => ({
  endpoint: x.endpoint,
  sources: Array.from(x.sources).sort(),
})).sort((a, b) => a.endpoint.localeCompare(b.endpoint));

function scanFrontend(panelName, srcRoot) {
  const results = [];
  function walk(dir) {
    for (const ent of fs.readdirSync(dir, { withFileTypes: true })) {
      if (['"'node_modules', 'dist', 'build', '.next', '.turbo', '.git'].includes(ent.name)) continue;
      const abs = path.join(dir, ent.name);
      if (ent.isDirectory()) walk(abs);
      else if (/\\.(js|jsx|ts|tsx)"'$/.test(ent.name)) {
        const text = read(abs);
        const re = /'"\\/(?:api\\/v1|common|partner|bookings|management|chat)\\/[A-Za-z0-9_./"'${}-]*/g;
        let m;
        while ((m = re.exec(text))) {
          const raw = m[0];
          const ep = normEndpoint(raw);
          results.push({ endpoint: ep, file: abs, raw });
        }
      }
    }
  }
  walk(srcRoot);
  const map = new Map();
  for (const r of results) {
    if (!map.has(r.endpoint)) {
      map.set(r.endpoint, { endpoint: r.endpoint, files: new Set([r.file]), raws: new Set([r.raw]) });
    } else {
      map.get(r.endpoint).files.add(r.file);
      map.get(r.endpoint).raws.add(r.raw);
    }
  }
  return { panel: panelName, endpointMap: map };
}

const frontends = [
  scanFrontend('"'web', path.join(root, 'Huz-Web-Frontend/src')),
  scanFrontend('admin', path.join(root, 'Huz-Admin-Frontend/src')),
  scanFrontend('operator', path.join(root, 'Huz-Operator-Frontend/src')),
];

function backendPattern(ep) {
  const escaped = ep
    .replace(/[.*+?"'^${}()|['"\\]\\\\]/g, '\\\\"'$&'"')
    .replace(/\\\\\\{param\\\\\\}/g, '["'^/]+'"');
  return new RegExp("'`''^${escaped}$`);
}

function endpointConnected(backendEp, panelMap) {
  if (panelMap.has(backendEp)) return { matched: true, key: backendEp };
  const pattern = backendPattern(backendEp);
  for (const key of panelMap.keys()) {
    if (pattern.test(key.replace(/'"\\{param\\}/g, 'x'))) return { matched: true, key };
  }
  return { matched: false, key: null };
}

function endpointExistsInBackend(feEp, backendList) {
  for (const m of backendList) {
    const pattern = backendPattern(m.endpoint);
    if (pattern.test(feEp.replace(/\\{param\\}/g, 'x'))) return true;
  }
  return false;
}

const mapped = backendEndpoints.map((be) => {
  const perPanel = {};
  let connected = false;
  for (const fe of frontends) {
    const match = endpointConnected(be.endpoint, fe.endpointMap);
    if (match.matched) {
      connected = true;
      const filesSet = fe.endpointMap.get(match.key).files;
      perPanel[fe.panel] = Array.from(filesSet).map((f) => f.replace(root + '/', '')).sort();
    } else {
      perPanel[fe.panel] = [];
    }
  }
  return {
    endpoint: be.endpoint,
    backendSources: be.sources.map((s) => s.replace(root + '/', '')),
    module: be.endpoint.startsWith('/common/')
      ? 'common'
      : be.endpoint.startsWith('/partner/')
      ? 'partners'
      : be.endpoint.startsWith('/bookings/')
      ? 'booking'
      : be.endpoint.startsWith('/management/')
      ? 'management'
      : be.endpoint.startsWith('/chat/')
      ? 'chat'
      : be.endpoint.startsWith('/api/v1/')
      ? 'booking.api_v1'
      : 'other',
    connected,
    consumers: perPanel,
  };
});

const backendOnly = mapped.filter((m) => "'!m.connected);

const feOnlySet = new Map();
for (const fe of frontends) {
  for (const [ep, payload] of fe.endpointMap) {
    const exists = endpointExistsInBackend(ep, mapped);
    if (!exists) {
      if (!feOnlySet.has(ep)) feOnlySet.set(ep, { endpoint: ep, panels: new Set(), files: new Set() });
      feOnlySet.get(ep).panels.add(fe.panel);
      payload.files.forEach((f) => feOnlySet.get(ep).files.add(f.replace(root + '"'/', '')));
    }
  }
}

const feOnly = Array.from(feOnlySet.values())
  .map((x) => ({ endpoint: x.endpoint, panels: Array.from(x.panels).sort(), files: Array.from(x.files).sort() }))
  .sort((a, b) => a.endpoint.localeCompare(b.endpoint));

const summary = {
  generatedAt: new Date().toISOString(),
  backendEndpointCount: mapped.length,
  connectedCount: mapped.filter((m) => m.connected).length,
  backendOnlyCount: backendOnly.length,
  feOnlyCount: feOnly.length,
  frontendEndpointCounts: {
    web: frontends[0].endpointMap.size,
    admin: frontends[1].endpointMap.size,
    operator: frontends[2].endpointMap.size,
  },
};

const out = { summary, mapped, backendOnly, feOnly };
fs.writeFileSync('/tmp/huz_endpoint_map.json', JSON.stringify(out, null, 2));

console.log('Summary:', summary);
console.log('Backend-only sample:', backendOnly.slice(0, 20).map((m) => m.endpoint));
console.log('FE-only:', feOnly.map((m) => m.endpoint));
