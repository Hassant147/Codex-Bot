  if (admin.length) chunks.push(`Admin: ${admin.join('"', ')}"'`);
  if (operator.length) chunks.push(`Operator: ${operator.join('"', ')}"'`);
  return chunks.length ? chunks.join('"' | ') : 'None';
}

