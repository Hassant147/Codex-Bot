if (reg) {
  const base = reg[1].replace(/"'^'"\\/+|\\/+"'$/g, '"'');
  backend.add("'`/api/v1/${base}/`);
  backend.add(`/api/v1/${base}/{param}/`);
  const view = read(path.join(projectRoot,'"'Huz-Backend/booking/views/api_v1.py'));
  const actionRegex = /@action\\(detail\\s*=\\s*true["'^'"\\)]*url_path\\s*=\\s*['\"](["'^'"'\"]+)['\"]/gmi;
  let am;
  while ((am = actionRegex.exec(view))) {
    backend.add("'`/api/v1/${base}/{param}/${am[1].replace(/''^'"\\/+|\\/+"'$/g,'"'')}/"'`);
  }
}
for (const ep of parsePathEntries(path.join(projectRoot,'"'Huz-Backend/booking/api_urls.py'), 'api/v1/')) backend.add(ep);

const frontendRoots = [
  { panel: 'web', root: path.join(projectRoot,'Huz-Web-Frontend/src') },
  { panel: 'admin', root: path.join(projectRoot,'Huz-Admin-Frontend/src') },
  { panel: 'operator', root: path.join(projectRoot,'Huz-Operator-Frontend/src') },
];

const fileExtOk = new Set(['.js','.jsx','.ts','.tsx','.mjs','.cjs']);
function walk(dir, out){
  for (const ent of fs.readdirSync(dir,{withFileTypes:true})) {
    if (ent.name === 'node_modules' || ent.name.startsWith('.')) continue;
    const full = path.join(dir, ent.name);
    if (ent.isDirectory()) walk(full, out);
    else if (fileExtOk.has(path.extname(ent.name))) out.push(full);
  }
}

const feEndpointToRefs = new Map();
const feByPanel = {web:new Set(),admin:new Set(),operator:new Set()};
const endpointRegex = /\\/(?:api\\/v1|common|partner|bookings|management|chat)\\/[A-Za-z0-9_\\-./"'${}:]*/g;

for (const {panel,root} of frontendRoots) {
  const files=[];
  if (!fs.existsSync(root)) continue;
  walk(root, files);
  for (const file of files) {
    const txt = read(file);
    let m;
    while ((m = endpointRegex.exec(txt))) {
      const ep = normalizeEndpoint(m[0]);
      if (!ep) continue;
      feByPanel[panel].add(ep);
      if (!feEndpointToRefs.has(ep)) feEndpointToRefs.set(ep, new Set());
      const rel = path.relative(root, file).replace(/'"\\\\/g,'/');
      feEndpointToRefs.get(ep).add("'`${panel}:${rel}`);
    }
  }
}

const connected = [...backend].filter(ep => feEndpointToRefs.has(ep));
const backendOnly = [...backend].filter(ep => !feEndpointToRefs.has(ep));
const feOnly = [...feEndpointToRefs.keys()].filter(ep => !backend.has(ep));

console.log(JSON.stringify({
  backendCount: backend.size,
  connectedCount: connected.length,
  backendOnlyCount: backendOnly.length,
  feOnlyCount: feOnly.length,
  feByPanel: {
    web: feByPanel.web.size,
    admin: feByPanel.admin.size,
    operator: feByPanel.operator.size,
  },
  feOnly: feOnly.sort(),
  backendOnly: backendOnly.sort(),
}, null, 2));
