diff --git a/src/features/marketingPages/leadCaptureDrafts.js b/src/features/marketingPages/leadCaptureDrafts.js
new file mode 100644
index 0000000000000000000000000000000000000000..8cda0e145a20feb0dba7deffa2979d68bb13f460
--- /dev/null
+++ b/src/features/marketingPages/leadCaptureDrafts.js
@@ -0,0 +1,77 @@
+const LEAD_DRAFT_STORAGE_KEY = "huz:marketingLeadDrafts";
+const MAX_STORED_DRAFTS = 20;
+
+const sanitizeSource = (source) =>
+  (source || "lead")
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, "-")
+    .replace(/^-+|-+$/g, "");
+
+const createDraftId = (source) => {
+  const sourceToken = sanitizeSource(source);
+  const timestampToken = Date.now().toString(36);
+  const randomToken = Math.random().toString(36).slice(2, 8);
+  return `${sourceToken}-${timestampToken}-${randomToken}`;
+};
+
+const sanitizeValues = (values = {}) =>
+  Object.entries(values).reduce((result, [key, value]) => {
+    const normalizedValue = typeof value === "string" ? value.trim() : "";
+
+    if (normalizedValue) {
+      result[key] = normalizedValue;
+    }
+
+    return result;
+  }, {});
+
+const readStoredDrafts = () => {
+  if (typeof window === "undefined") {
+    return [];
+  }
+
+  try {
+    const rawDrafts = window.localStorage.getItem(LEAD_DRAFT_STORAGE_KEY);
+
+    if (!rawDrafts) {
+      return [];
+    }
+
+    const parsedDrafts = JSON.parse(rawDrafts);
+
+    if (!Array.isArray(parsedDrafts)) {
+      return [];
+    }
+
+    return parsedDrafts;
+  } catch (error) {
+    return [];
+  }
+};
+
+const storeDrafts = (drafts) => {
+  if (typeof window === "undefined") {
+    return;
+  }
+
+  try {
+    window.localStorage.setItem(LEAD_DRAFT_STORAGE_KEY, JSON.stringify(drafts));
+  } catch (error) {
+    // Ignore storage write failures to keep submit UX non-blocking.
+  }
+};
+
+export const saveLeadCaptureDraft = ({ source, values }) => {
+  const draft = {
+    id: createDraftId(source),
+    source: sanitizeSource(source),
+    submittedAt: new Date().toISOString(),
+    values: sanitizeValues(values),
+  };
+
+  const existingDrafts = readStoredDrafts();
+  const nextDrafts = [draft, ...existingDrafts].slice(0, MAX_STORED_DRAFTS);
+  storeDrafts(nextDrafts);
+
+  return draft;
+};
