import React from "react";
import { Transition } from "@headlessui/react";
import { motion } from "framer-motion";
import {
  ArrowLeft,
  ArrowRight,
  Check,
  ChevronDown,
  Search,
} from "lucide-react";
import AppPromoSection from "../../pages/HomePage/components/AppPromoSection";
import {
  HOMEPAGE_MAIN_SECTION_PADDING,
  HOMEPAGE_SECTION_STACK,
} from "../../pages/HomePage/homepageLayout";
import BrandPageShell from "../../shared/layout/BrandPageShell";

const defaultMotion = {
  initial: { opacity: 0, y: 20 },
  animate: { opacity: 1, y: 0 },
  transition: { duration: 0.45 },
};

const surfaceCardClassName =
  "homepage-section-surface overflow-hidden p-5 sm:p-6 md:p-8 xl:p-10";

const softCardClassName =
  "homepage-soft-card overflow-hidden p-5 sm:p-6";

const renderItemIcon = (icon, className = "h-5 w-5") => {
  if (!icon) {
    return <Check className={className} />;
  }

  if (React.isValidElement(icon)) {
    return icon;
  }

  if (typeof icon === "function") {
    const Icon = icon;
    return <Icon className={className} />;
  }

  return <span className="text-lg leading-none">{icon}</span>;
};

export const StaticMotionBlock = ({
  as = "div",
  initial = defaultMotion.initial,
  animate = defaultMotion.animate,
  transition = defaultMotion.transition,
  className,
  style,
  children,
}) => {
  const MotionComponent = motion[as] || motion.div;

  return (
    <MotionComponent
      initial={initial}
      animate={animate}
      transition={transition}
      className={className}
      style={style}
    >
      {children}
    </MotionComponent>
  );
};

export const StaticBackButton = ({
  onClick,
  wrapperClassName = "pt-1",
  buttonClassName =
    "group inline-flex items-center gap-3 text-[#0F4C5C] transition-colors hover:text-[#0F4C5C]/80",
  iconWrapperClassName =
    "flex h-10 w-10 items-center justify-center rounded-full border border-[#c7ddd6] bg-white shadow-[0_10px_24px_rgba(0,92,67,0.08)] transition-transform duration-300 group-hover:-translate-x-0.5",
  iconClassName = "h-4 w-4",
  labelClassName = "text-sm font-semibold",
  label = "Back",
}) => (
  <div className={wrapperClassName}>
    <button type="button" onClick={onClick} className={buttonClassName}>
      <div className={iconWrapperClassName}>
        <ArrowLeft className={iconClassName} />
      </div>
      <span className={labelClassName}>{label}</span>
    </button>
  </div>
);

export const StaticHeroSection = ({
  eyebrow,
  title,
  description,
  highlights = [],
  stats = [],
  aside = null,
  actions = null,
}) => {
  const sidePanel = aside || stats.length > 0;

  return (
    <StaticMotionBlock className="homepage-section-surface relative overflow-hidden">
      <div className="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(209,165,84,0.16)_0%,rgba(209,165,84,0)_34%),radial-gradient(circle_at_bottom_right,rgba(0,147,108,0.12)_0%,rgba(0,147,108,0)_40%)]" />

      <div
        className={`relative grid gap-6 p-5 sm:p-6 md:p-8 xl:p-10 ${
          sidePanel ? "xl:grid-cols-[minmax(0,1fr)_320px]" : ""
        }`}
      >
        <div className="space-y-5">
          {eyebrow ? <span className="section-label">{eyebrow}</span> : null}

          <div className="space-y-4">
            <h1 className="section-heading text-3xl sm:text-4xl xl:text-5xl">
              {title}
            </h1>
            {description ? (
              <p className="max-w-3xl text-base leading-relaxed text-[#4b5769] sm:text-lg">
                {description}
              </p>
            ) : null}
          </div>

          {highlights.length ? (
            <div className="flex flex-wrap gap-3">
              {highlights.map((item) => (
                <div
                  key={item}
                  className="inline-flex items-center gap-2 rounded-full border border-[#d6e7e0] bg-white/90 px-4 py-2 text-sm font-semibold text-[#1f3440] shadow-[0_8px_22px_rgba(0,92,67,0.08)]"
                >
                  <Check className="h-4 w-4 text-[#00936c]" />
                  <span>{item}</span>
                </div>
              ))}
            </div>
          ) : null}

          {actions}
        </div>

        {sidePanel ? (
          <div className="space-y-4">
            {aside}

            {!aside && stats.length ? (
              <div className={softCardClassName}>
                <div className="space-y-4">
                  {stats.map((stat) => (
                    <div
                      key={stat.label}
                      className="rounded-[1.35rem] border border-[#dceae3] bg-white px-4 py-4 shadow-[0_8px_20px_rgba(0,92,67,0.05)]"
                    >
                      <p className="text-3xl font-black tracking-tight text-[#0F4C5C]">
                        {stat.value}
                      </p>
                      <p className="mt-1 text-sm font-semibold text-[#304455]">
                        {stat.label}
                      </p>
                      {stat.description ? (
                        <p className="mt-2 text-sm leading-relaxed text-[#667085]">
                          {stat.description}
                        </p>
                      ) : null}
                    </div>
                  ))}
                </div>
              </div>
            ) : null}
          </div>
        ) : null}
      </div>
    </StaticMotionBlock>
  );
};

export const StaticPageSection = ({
  eyebrow,
  title,
  description,
  children,
  className = "",
  contentClassName = "space-y-6",
}) => (
  <StaticMotionBlock className={`${surfaceCardClassName} ${className}`.trim()}>
    <div className={contentClassName}>
      {eyebrow ? <span className="section-label">{eyebrow}</span> : null}
      {title ? (
        <div className="space-y-3">
          <h2 className="section-heading text-2xl sm:text-3xl">{title}</h2>
          {description ? (
            <p className="max-w-3xl text-sm leading-relaxed text-[#4b5769] sm:text-base">
              {description}
            </p>
          ) : null}
        </div>
      ) : null}
      {children}
    </div>
  </StaticMotionBlock>
);

export const StaticTextSection = ({
  eyebrow,
  title,
  description,
  paragraphs = [],
  aside = null,
  className = "",
}) => (
  <StaticPageSection
    eyebrow={eyebrow}
    title={title}
    description={description}
    className={className}
  >
    <div
      className={`grid gap-6 ${
        aside ? "xl:grid-cols-[minmax(0,1fr)_320px]" : ""
      }`}
    >
      <div className="space-y-4">
        {paragraphs.map((paragraph) => (
          <p
            key={paragraph}
            className="text-sm leading-relaxed text-[#4b5769] sm:text-base"
          >
            {paragraph}
          </p>
        ))}
      </div>

      {aside ? <div>{aside}</div> : null}
    </div>
  </StaticPageSection>
);

export const StaticMetricGridSection = ({
  eyebrow,
  title,
  description,
  items,
  columnsClassName = "md:grid-cols-2 xl:grid-cols-3",
}) => (
  <StaticPageSection eyebrow={eyebrow} title={title} description={description}>
    <div className={`grid gap-4 ${columnsClassName}`.trim()}>
      {items.map((item, index) => (
        <StaticMotionBlock
          key={item.id || item.label}
          transition={{ duration: 0.35, delay: index * 0.05 }}
          className="homepage-soft-card homepage-card-stack p-5 sm:p-6"
        >
          <div className="space-y-3">
            <p className="text-[11px] font-bold uppercase tracking-[0.16em] text-[#8b97a5]">
              {item.label}
            </p>
            <p className="text-3xl font-black tracking-tight text-[#0F4C5C] sm:text-4xl">
              {item.value}
            </p>
            {item.description ? (
              <p className="text-sm leading-relaxed text-[#4b5769]">
                {item.description}
              </p>
            ) : null}
          </div>
        </StaticMotionBlock>
      ))}
    </div>
  </StaticPageSection>
);

export const StaticFeatureGridSection = ({
  eyebrow,
  title,
  description,
  items,
  columnsClassName = "md:grid-cols-2 xl:grid-cols-3",
}) => (
  <StaticPageSection eyebrow={eyebrow} title={title} description={description}>
    <div className={`grid gap-4 ${columnsClassName}`.trim()}>
      {items.map((item, index) => (
        <StaticMotionBlock
          key={item.id || item.title}
          transition={{ duration: 0.35, delay: index * 0.05 }}
          className="homepage-surface-card homepage-card-stack p-5 sm:p-6"
        >
          <div className="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#0F4C5C] text-white shadow-[0_10px_24px_rgba(0,92,67,0.16)]">
            {renderItemIcon(item.icon)}
          </div>

          <div className="mt-5 space-y-3">
            {item.kicker ? (
              <p className="text-[11px] font-bold uppercase tracking-[0.16em] text-[#8b97a5]">
                {item.kicker}
              </p>
            ) : null}
            <h3 className="text-xl font-bold text-[#1a2734]">{item.title}</h3>
            <p className="text-sm leading-relaxed text-[#4b5769]">
              {item.description}
            </p>
          </div>

          {item.footer ? (
            <div className="homepage-card-footer text-sm leading-relaxed text-[#667085]">
              {item.footer}
            </div>
          ) : null}
        </StaticMotionBlock>
      ))}
    </div>
  </StaticPageSection>
);

export const StaticComingSoonSection = ({
  title,
  description,
  expectItems = [],
  footerText,
  primaryAction,
  secondaryAction,
  eyebrow = "Launching soon",
}) => (
  <StaticMotionBlock className="homepage-section-surface overflow-hidden">
    <div className="bg-gradient-to-br from-[#0d4d46] via-[#0b695b] to-[#0f8f6b] p-5 text-white sm:p-6 md:p-8 xl:p-10">
      <div className="grid gap-6 xl:grid-cols-[minmax(0,1fr)_340px] xl:items-start">
        <div className="space-y-5">
          <span className="inline-flex items-center rounded-full border border-white/20 bg-white/10 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.18em] text-white/80">
