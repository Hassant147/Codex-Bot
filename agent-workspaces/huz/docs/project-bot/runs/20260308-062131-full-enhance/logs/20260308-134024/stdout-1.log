            </p>
            <p className="text-lg text-gray-700 leading-relaxed">
              For more information about our core values, contact us at [contact information].
            </p>
          </div>
        </motion.div> */}
      </div>

      <Footer />
    </main>
  );
};

export default CoreValues;
