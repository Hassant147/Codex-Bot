import React from "react";
import { Compass, ShieldCheck, Sparkles, Users } from "lucide-react";
import { useNavigate } from "react-router-dom";
import StaticContentPage, {
  StaticFeatureGridSection,
  StaticHeroSection,
  StaticMetricGridSection,
  StaticTextSection,
} from "../../features/staticPages/StaticContentPage";

const fastFacts = [
  {
    id: 1,
    label: "Active packages",
    value: "7.7M+",
    description: "Package listings and offers surfaced across the wider marketplace.",
  },
  {
    id: 2,
    label: "Cities and towns",
    value: "100K+",
    description: "Locations represented through the travel and pilgrimage ecosystem.",
  },
  {
    id: 3,
    label: "Countries and regions",
    value: "220+",
    description: "Reach across destinations and travellers exploring Hajj and Umrah options.",
  },
  {
    id: 4,
    label: "Guest arrivals",
    value: "1.5B+",
    description: "Historic pilgrimage demand that shapes the scale of planning and support.",
  },
  {
    id: 5,
    label: "Hosts and partners",
    value: "5M+",
    description: "Agencies, vendors, and service providers participating in the market.",
  },
  {
    id: 6,
    label: "Earnings generated",
    value: "$250B+",
    description: "All-time travel value represented across the broader Hajj and Umrah space.",
  },
];

const promiseCards = [
  {
    id: 1,
    icon: Compass,
    title: "Guided planning",
    description:
      "From package discovery to departure-day preparation, Huz keeps the pilgrim journey organized around the decisions that matter most.",
  },
  {
    id: 2,
    icon: ShieldCheck,
    title: "Trusted operators",
    description:
      "The platform is built around trusted package providers, transparent comparisons, and clear service expectations before you commit.",
  },
  {
    id: 3,
    icon: Users,
    title: "Human support",
    description:
      "Visa processing, accommodation coordination, and transport planning stay visible so travellers can focus on worship and peace of mind.",
  },
  {
    id: 4,
    icon: Sparkles,
    title: "Seamless experience",
    description:
      "Every step is designed to reduce friction and keep the experience spiritually focused instead of administratively overwhelming.",
  },
];

const AboutUs = () => {
  const navigate = useNavigate();

  return (
    <StaticContentPage backButton={{ onClick: () => navigate("/") }}>
      <StaticHeroSection
        eyebrow="About Huz"
        title="A calmer way to plan sacred travel"
        description="HajjUmrah.co is built to make pilgrimage planning trustworthy, structured, and spiritually focused. We connect travellers with comprehensive Hajj and Umrah packages while keeping planning support visible from visa processing to accommodation and transport."
        highlights={[
          "One branded journey across discovery, guidance, and support",
          "Clear package comparisons and trusted operators",
          "Planning support that stays practical and pilgrim-first",
        ]}
        stats={[
          {
            value: "24/7",
            label: "Support mindset",
            description:
              "Operational guidance is designed to stay available whenever a traveller needs clarity.",
          },
          {
            value: "End-to-end",
            label: "Journey coverage",
            description:
              "Discovery, booking, logistics, and preparation are treated as one connected experience.",
          },
        ]}
      />

      <StaticTextSection
        eyebrow="Our mission"
        title="Built around confidence, not confusion"
        paragraphs={[
          "Welcome to HajjUmrah.co, your trusted partner in making your pilgrimage to the holy cities of Mecca and Medina a fulfilling and memorable experience.",
          "We specialize in providing comprehensive Hajj and Umrah packages tailored to meet the spiritual needs and comfort expectations of our travellers, with a dedicated team that keeps the journey meticulously planned and clearly explained.",
          "At HajjUmrah.co, the goal is a seamless and spiritually enriching pilgrimage so travellers can spend less energy navigating logistics and more energy focused on devotion and worship.",
        ]}
      />

      <StaticMetricGridSection
        eyebrow="Fast facts"
        title="A marketplace shaped by global pilgrimage demand"
        description="The scale below reflects the broader Hajj and Umrah ecosystem that informs the way Huz approaches trust, package discovery, and support."
        items={fastFacts}
      />

      <StaticFeatureGridSection
        eyebrow="What Huz delivers"
        title="The operating principles behind the platform"
        description="These are the shared service promises that keep the public routes aligned with the broader Huz design system."
        columnsClassName="md:grid-cols-2"
        items={promiseCards}
      />
    </StaticContentPage>
  );
};

export default AboutUs;
