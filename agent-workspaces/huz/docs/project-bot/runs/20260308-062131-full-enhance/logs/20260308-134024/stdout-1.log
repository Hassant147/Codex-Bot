          <div className="flex flex-wrap gap-3">
            {primaryAction ? (
              <button
                type="button"
                onClick={primaryAction.onClick}
                className="group inline-flex items-center gap-2.5 rounded-xl bg-white px-5 py-3 text-sm font-bold text-[#0F4C5C] shadow-[0_10px_24px_rgba(0,0,0,0.16)] transition-all hover:-translate-y-0.5"
              >
                <span>{primaryAction.label}</span>
                <ArrowRight className="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
              </button>
            ) : null}

            {secondaryAction ? (
              <button
                type="button"
                onClick={secondaryAction.onClick}
                className="inline-flex items-center gap-2 rounded-xl border border-white/25 bg-white/10 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/15"
              >
                {secondaryAction.label}
              </button>
            ) : null}
          </div>
        </div>

        <div className="homepage-soft-card bg-white/10 p-5 text-white backdrop-blur-sm sm:p-6">
          <div className="space-y-4">
            <p className="text-[11px] font-bold uppercase tracking-[0.18em] text-white/70">
              What to expect
            </p>
            <div className="space-y-3">
              {expectItems.map((item) => (
                <div
                  key={item}
                  className="flex items-start gap-3 rounded-[1.15rem] border border-white/12 bg-white/8 px-4 py-3"
                >
                  <div className="mt-0.5 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-white/14">
                    <Check className="h-4 w-4" />
                  </div>
                  <p className="text-sm leading-relaxed text-white/82">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </StaticMotionBlock>
);

export const StaticSupportSection = ({ title, description, cards }) => (
  <StaticFeatureGridSection
    eyebrow="Support"
    title={title}
    description={description}
    columnsClassName="md:grid-cols-2"
    items={cards}
  />
);

export const StaticFaqSection = ({
  eyebrow = "Help center",
  title,
  description,
  faqs,
  searchValue,
  onSearchChange,
  openIndex,
  onToggle,
  helperTitle = "Search the knowledge base",
  helperDescription,
  helperItems = [],
  emptyTitle = "No matching questions found",
  emptyDescription = "Try a broader keyword or browse the full list below.",
}) => (
  <div className="grid gap-6 xl:grid-cols-[320px_minmax(0,1fr)] xl:items-start">
    <StaticMotionBlock className={softCardClassName}>
      <div className="space-y-5">
        <div className="space-y-3">
          <span className="section-label">{eyebrow}</span>
          <h2 className="section-heading text-2xl sm:text-3xl">{title}</h2>
          {description ? (
            <p className="text-sm leading-relaxed text-[#4b5769] sm:text-base">
              {description}
            </p>
          ) : null}
        </div>

        <div className="space-y-3 rounded-[1.5rem] border border-[#dceae3] bg-white p-4 shadow-[0_10px_24px_rgba(0,92,67,0.05)]">
          <div className="space-y-1">
            <p className="text-sm font-semibold text-[#1a2734]">{helperTitle}</p>
            {helperDescription ? (
              <p className="text-sm leading-relaxed text-[#667085]">
                {helperDescription}
              </p>
            ) : null}
          </div>

          <label className="block">
            <span className="sr-only">Search questions</span>
            <div className="flex items-center gap-3 rounded-full border border-[#d0e4dc] bg-[#f7fbf9] px-4 py-3">
              <Search className="h-4 w-4 text-[#667085]" />
              <input
                type="text"
                value={searchValue}
                onChange={(event) => onSearchChange(event.target.value)}
                placeholder="Search questions"
                className="w-full border-none bg-transparent text-sm text-[#1a2734] outline-none placeholder:text-[#90a0ad]"
              />
            </div>
          </label>
        </div>

        {helperItems.length ? (
          <div className="space-y-3">
            {helperItems.map((item) => (
              <div
                key={item.title}
                className="rounded-[1.4rem] border border-[#dceae3] bg-white px-4 py-4 shadow-[0_10px_22px_rgba(0,92,67,0.04)]"
              >
                <p className="text-sm font-semibold text-[#1a2734]">{item.title}</p>
                <p className="mt-1 text-sm leading-relaxed text-[#667085]">
                  {item.description}
                </p>
              </div>
            ))}
          </div>
        ) : null}
      </div>
    </StaticMotionBlock>

    <StaticMotionBlock className={`${surfaceCardClassName} p-2 sm:p-3 md:p-4`}>
      <div className="space-y-3">
        {faqs.length ? (
          faqs.map((faq, index) => {
            const isOpen = openIndex === index;

            return (
              <div
                key={faq.question}
                className="overflow-hidden rounded-[1.35rem] border border-[#dceae3] bg-white shadow-[0_10px_24px_rgba(0,92,67,0.04)]"
              >
                <button
                  type="button"
                  onClick={() => onToggle(index)}
                  className="flex w-full items-center justify-between gap-4 px-5 py-4 text-left"
                >
                  <span className="text-sm font-semibold leading-relaxed text-[#1a2734] sm:text-base">
                    {faq.question}
                  </span>
                  <span
                    className={`flex h-9 w-9 items-center justify-center rounded-full border border-[#dceae3] bg-[#f7fbf9] text-[#0F4C5C] transition-transform ${
                      isOpen ? "rotate-180" : ""
                    }`}
                  >
                    <ChevronDown className="h-4 w-4" />
                  </span>
                </button>

                <Transition
                  show={isOpen}
                  enter="transition duration-200 ease-out"
                  enterFrom="opacity-0 -translate-y-1"
                  enterTo="opacity-100 translate-y-0"
                  leave="transition duration-150 ease-in"
                  leaveFrom="opacity-100 translate-y-0"
                  leaveTo="opacity-0 -translate-y-1"
                >
                  <div className="border-t border-[#edf4f1] px-5 py-4">
                    <p className="text-sm leading-relaxed text-[#4b5769] sm:text-base">
                      {faq.answer}
                    </p>
                  </div>
                </Transition>
              </div>
            );
          })
        ) : (
          <div className="rounded-[1.35rem] border border-dashed border-[#c8ddd4] bg-[#f8fcfa] px-5 py-8 text-center">
            <p className="text-lg font-bold text-[#1a2734]">{emptyTitle}</p>
            <p className="mt-2 text-sm leading-relaxed text-[#667085]">
              {emptyDescription}
            </p>
          </div>
        )}
      </div>
    </StaticMotionBlock>
  </div>
);

export const StaticLegalPage = ({
  backButton,
  eyebrow = "Legal",
  title,
  description,
  highlights = [],
  sidebarTitle = "This page covers",
  sidebarItems = [],
  children,
}) => (
  <StaticContentPage
    backButton={backButton}
    hero={
      <StaticHeroSection
        eyebrow={eyebrow}
        title={title}
        description={description}
        highlights={highlights}
      />
    }
  >
    <div
      className={`grid gap-6 ${
        sidebarItems.length ? "xl:grid-cols-[260px_minmax(0,1fr)]" : ""
      }`}
    >
      {sidebarItems.length ? (
        <StaticMotionBlock className="space-y-4 xl:sticky xl:top-28 xl:self-start">
          <div className={softCardClassName}>
            <div className="space-y-4">
              <p className="text-[11px] font-bold uppercase tracking-[0.16em] text-[#8b97a5]">
                {sidebarTitle}
              </p>
              <div className="space-y-3">
                {sidebarItems.map((item) => (
                  <div
                    key={item}
                    className="rounded-[1.15rem] border border-[#dceae3] bg-white px-4 py-3 text-sm font-semibold text-[#304455] shadow-[0_8px_18px_rgba(0,92,67,0.04)]"
                  >
                    {item}
                  </div>
                ))}
              </div>
            </div>
          </div>
        </StaticMotionBlock>
      ) : null}

      <StaticMotionBlock as="article" className={surfaceCardClassName}>
        {children}
      </StaticMotionBlock>
    </div>
  </StaticContentPage>
);

const StaticContentPage = ({
  backButton,
  children,
  hero = null,
  mainClassName = HOMEPAGE_MAIN_SECTION_PADDING,
  preFooter,
  preFooterClassName = "pb-10 pt-2",
  shellClassName = HOMEPAGE_SECTION_STACK,
  showPromo = true,
  withAmbient = true,
}) => {
  const resolvedPreFooter =
    typeof preFooter !== "undefined"
      ? preFooter
      : showPromo
        ? <AppPromoSection />
        : null;

  return (
    <BrandPageShell
      mainClassName={mainClassName}
      preFooter={resolvedPreFooter}
      preFooterClassName={preFooterClassName}
      shellClassName={shellClassName}
      withAmbient={withAmbient}
    >
      {backButton ? <StaticBackButton {...backButton} /> : null}
      {hero}
      {children}
    </BrandPageShell>
  );
};

export default StaticContentPage;
