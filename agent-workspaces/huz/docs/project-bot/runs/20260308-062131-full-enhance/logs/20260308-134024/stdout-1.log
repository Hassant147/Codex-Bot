import React from "react";
import {
  BadgeCheck,
  HeartHandshake,
  Lightbulb,
  ShieldCheck,
  Sparkles,
  Users,
} from "lucide-react";
import { useNavigate } from "react-router-dom";
import StaticContentPage, {
  StaticFeatureGridSection,
  StaticHeroSection,
  StaticTextSection,
} from "../../features/staticPages/StaticContentPage";

const coreValues = [
  {
    id: 1,
    icon: ShieldCheck,
    title: "Integrity",
    description:
      "Integrity is at the heart of our business. We are committed to honesty, transparency, and ethical practices in all our interactions so trust stays central across travellers, vendors, and partners.",
  },
  {
    id: 2,
    icon: HeartHandshake,
    title: "Customer focus",
    description:
      "Our customers are at the center of everything we do. We work to understand their needs, reduce friction, and support a meaningful Hajj and Umrah experience from start to finish.",
  },
  {
    id: 3,
    icon: Lightbulb,
    title: "Innovation",
    description:
      "We believe thoughtful technology can improve how people research, compare, and book sacred travel without making the journey feel generic or transactional.",
  },
  {
    id: 4,
    icon: Users,
    title: "Community",
    description:
      "We foster a supportive environment among users, partners, and the wider Muslim community, and we aim to create value that extends beyond the platform itself.",
  },
  {
    id: 5,
    icon: BadgeCheck,
    title: "Inclusivity",
    description:
      "Hajj and Umrah should be accessible to all Muslims. We are committed to affordable options and service choices that reflect the range of traveller needs and circumstances.",
  },
  {
    id: 6,
    icon: Sparkles,
    title: "Excellence",
    description:
      "From customer support to service delivery, we pursue quality relentlessly so the Huz experience feels dependable, polished, and worthy of the journey it supports.",
  },
];

const operatingNotes = [
  "These values guide the way Huz designs its pages, content systems, and traveller-facing flows.",
  "They also explain why the public static routes are being migrated onto one shared, premium shell instead of staying as disconnected one-off page implementations.",
];

const CoreValues = () => {
  const navigate = useNavigate();

  return (
    <StaticContentPage backButton={{ onClick: () => navigate("/") }}>
      <StaticHeroSection
        eyebrow="Core values"
        title="The standards that shape the Huz experience"
        description="Huzzumrah.co uses a small set of operating values to guide product decisions, service behaviour, and the way pilgrimage planning should feel across every public and protected route."
        highlights={[
          "Transparent, pilgrim-first decision making",
          "Consistent quality across support and product design",
          "Technology that serves clarity instead of adding noise",
        ]}
      />

      <StaticTextSection
        eyebrow="Why it matters"
        title="A design system should reflect product values"
        paragraphs={[
          "At Hajjumrah.co, our core values are the foundation of everything we do. They guide our actions, shape our culture, and reflect our commitment to providing exceptional Hajj and Umrah services.",
          ...operatingNotes,
        ]}
      />

      <StaticFeatureGridSection
        eyebrow="The six commitments"
        title="Principles that stay visible in every route"
        description="Each value below carries forward the intent of the original content while presenting it through the shared branded page system."
        items={coreValues}
      />
    </StaticContentPage>
  );
};

export default CoreValues;
