import React from "react";
import { Headphones, ShieldCheck, Wallet } from "lucide-react";
import { useLocation, useNavigate } from "react-router-dom";
import StaticContentPage, {
  StaticComingSoonSection,
  StaticHeroSection,
  StaticSupportSection,
} from "../../features/staticPages/StaticContentPage";

const supportCards = [
  {
    id: 1,
    icon: ShieldCheck,
    title: "Trusted operators",
    description:
      "We are preparing package launches around verified providers, clear inclusions, and reliable journey planning.",
  },
  {
    id: 2,
    icon: Wallet,
    title: "Transparent pricing",
    description:
      "Package releases will keep pricing, itinerary details, and cost expectations easy to compare before booking.",
  },
  {
    id: 3,
    icon: Headphones,
    title: "Ongoing support",
    description:
      "Customer support remains a core part of the launch plan so travellers can move from interest to booking with confidence.",
  },
];

const ComingSoon = () => {
  const navigate = useNavigate();
  const location = useLocation();

  const urlParams = new URLSearchParams(location.search);
  const packageType = urlParams.get("type") || "Hajj";
  const normalizedType = packageType.toLowerCase() === "umrah" ? "Umrah" : "Hajj";

  return (
    <StaticContentPage backButton={{ onClick: () => navigate("/") }}>
      <StaticHeroSection
        eyebrow="Roadmap"
        title={`${normalizedType} packages are on the way`}
        description={`We are preparing a stronger ${normalizedType.toLowerCase()} discovery and booking experience so travellers can compare trusted packages, understand inclusions clearly, and move into the next step without hunting through disconnected content.`}
        highlights={[
          `Verified ${normalizedType.toLowerCase()} package providers`,
          "Detailed itineraries and accommodation visibility",
          "Transparent pricing and traveller support",
        ]}
      />

      <StaticComingSoonSection
        title={`${normalizedType} package launch in progress`}
        description={`We are working on the next release of Huz package discovery so travellers can browse ${normalizedType.toLowerCase()} offers with better structure, stronger trust signals, and clearer support details.`}
        expectItems={[
          `Comprehensive ${normalizedType.toLowerCase()} packages from verified operators`,
          "Detailed itineraries, accommodation notes, and transport details",
          "Competitive pricing with clearer cost breakdowns",
          "Traveller support before and during the journey",
        ]}
        footerText={`Stay updated on our progress and be the first to know when ${normalizedType.toLowerCase()} packages become available.`}
        primaryAction={{
          label: "Back to Home",
          onClick: () => navigate("/"),
        }}
        secondaryAction={{
          label: "Learn More About Us",
          onClick: () => navigate("/about-us"),
        }}
      />

      <StaticSupportSection
        title={`Why Huz is preparing this ${normalizedType.toLowerCase()} release carefully`}
        description="The public package experience is being aligned to the same branded page system used across the rest of the revamp."
        cards={supportCards}
      />
    </StaticContentPage>
  );
};

export default ComingSoon;
