def _normalize_package_type(raw_value):
    if raw_value in (None, ""):
        return None
    value = str(raw_value).strip()
    lower = value.lower()
    if lower == "hajj":
        return "Hajj"
    if lower == "umrah":
        return "Umrah"
    return None


